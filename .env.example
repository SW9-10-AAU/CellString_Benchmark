DUCKDB_PATH=/absolute/path/to/cellstring.duckdb
DUCKDB_THREADS=1
DUCKDB_THREAD_SCALING=1,2,4,8,16
RUN_LABEL=local
CACHE_STATE=warm

LINESTRING_SCHEMA=p10
CELLSTRING_SCHEMA=db_design1_v3

TRAJECTORY_ID_SOURCE_TABLE=db_design1_v3.trajectory_cs
TRAJECTORY_ID_COLUMN=trajectory_id
TRAJECTORY_SAMPLE_SIZE=400
STOP_ID_SOURCE_TABLE=db_design1_v3.stop_cs
STOP_ID_COLUMN=stop_id
STOP_SAMPLE_SIZE=400
AREA_ID_SOURCE_TABLE=db_design1_v3.area_cs
CROSSING_ID_SOURCE_TABLE=p10.crossing_ls

# Optional: comma-separated benchmark names. Empty = run all benchmarks.
# BENCHMARKS="Temporal range query (1 day),Temporal range query (1 week),Temporal range query (1 month)"
# BENCHMARKS="Spatio-temporal range query - area 1 (1 day),Spatio-temporal range query - area 2 (1 day),Spatio-temporal range query - area 3 (1 day)"
BENCHMARKS=

# Optional: start timestamp used by temporal_range_benchmark.py
TEMPORAL_RANGE_START='2025-12-01 00:00:00'

# Cold/hot benchmark: comma-separated benchmark names (empty = all spatio-temporal)
# Run with: sudo python -m benchmarking.cold_hot_main
# COLD_HOT_BENCHMARKS=